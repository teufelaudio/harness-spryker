{% set command = @('services.redis-session.options')
  | filter(v => v is not empty)
  | map((value, var) => '--' ~ var ~ ' ' ~ value|join(' --' ~ var ~ ' '))
  | reduce((carry, v) => carry|merge([v]), []) %}
  redis-session:
    image: {{ @('services.redis-session.image') }}
    command: {{ to_nice_yaml(command, 2, 6) }}
    networks:
      - private
