  mongodb:
    image: {{ @('services.mongodb.image') }}
    environment: {{ to_nice_yaml(docker_compose_escape(deep_merge([
        @('services.mongodb.environment'),
        @('services.mongodb.environment_dynamic'),
        @('services.mongodb.environment_secrets')
      ])), 2, 6) | raw }}
    networks:
      - private
    expose:
      - 27017
    volumes:
      - /data/db
